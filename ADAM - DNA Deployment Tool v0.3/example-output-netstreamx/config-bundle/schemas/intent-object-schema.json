{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://adam.io/schemas/intent-object/v1.1",
  "title": "ADAM Intent Object",
  "description": "Structured, versioned, immutable JSON for every request into ADAM. Six-stage execution pipeline.",
  "type": "object",
  "required": ["intent_id","timestamp","source","desired_outcomes","constraints"],
  "properties": {
    "intent_id":        { "type": "string", "format": "uuid" },
    "doctrine_version": { "type": "string" },
    "timestamp":        { "type": "string", "format": "date-time" },
    "source": {
      "type": "object",
      "required": ["user_id","role"],
      "properties": {
        "user_id":              { "type": "string" },
        "role":                 { "type": "string", "enum": ["director","executive","operator","system","customer"] },
        "director_id":          { "type": "string", "enum": ["ceo","cfo","legal_director","market_director","ciso","cpo","cto"] },
        "delegation_chain":     { "type": "array", "items": { "type": "object" } },
        "originating_agent_id": { "type": "string" },
        "customer_id":          { "type": "string" }
      }
    },
    "desired_outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["outcome_id","description","success_criteria"],
        "properties": {
          "outcome_id":       { "type": "string" },
          "description":      { "type": "string" },
          "success_criteria": { "type": "array", "items": { "type": "string" } },
          "priority":         { "type": "string", "enum": ["critical","high","medium","low"] }
        }
      }
    },
    "constraints":         { "type": "array", "items": { "type": "string" } },
    "risk_tolerance":      { "type": "object" },
    "urgency":             { "type": "string", "enum": ["routine","elevated","critical","emergency"] },
    "is_non_idempotent":   { "type": "boolean" },
    "approval_conditions": { "type": "array" },
    "core_graph_context":  { "type": "object" },
    "replay_marker": {
      "type": "object",
      "properties": {
        "original_intent_id":          { "type": "string" },
        "doctrine_version_at_original": { "type": "string" }
      }
    }
  }
}
