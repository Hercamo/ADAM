        <mxCell id="ov_legend" parent="layer_overlays" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#666;fontSize=11;fontStyle=1;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;shadow=1;" value="&lt;b&gt;Legend &amp;amp; Conventions&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;&lt;span style=&#39;color:#0078D4&#39;&gt;&amp;#9632;&lt;/span&gt; Azure &amp;nbsp;&amp;nbsp;&lt;span style=&#39;color:#FF9900&#39;&gt;&amp;#9632;&lt;/span&gt; AWS &amp;nbsp;&amp;nbsp;&lt;span style=&#39;color:#4285F4&#39;&gt;&amp;#9632;&lt;/span&gt; GCP &amp;nbsp;&amp;nbsp;&lt;span style=&#39;color:#82B366&#39;&gt;&amp;#9632;&lt;/span&gt; On-Prem &amp;nbsp;&amp;nbsp;&lt;span style=&#39;color:#00838F&#39;&gt;&amp;#9632;&lt;/span&gt; Governor Agents (teal) &amp;nbsp;&amp;nbsp;&lt;span style=&#39;color:#D6B656&#39;&gt;&amp;#9632;&lt;/span&gt; Human Directorship (gold)&lt;br/&gt;&lt;span style=&#39;color:#9673A6&#39;&gt;&amp;#9632;&lt;/span&gt; Data / Ledger &amp;nbsp;&amp;nbsp;&lt;span style=&#39;color:#B85450&#39;&gt;&amp;#9632;&lt;/span&gt; Security / Policy &amp;nbsp;&amp;nbsp;&lt;span style=&#39;color:#D79B00&#39;&gt;&amp;#9632;&lt;/span&gt; ADAM Governance &amp;nbsp;&amp;nbsp;&lt;span style=&#39;color:#F9A825&#39;&gt;&amp;#9632;&lt;/span&gt; Twins / Meta&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Edges&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;Solid: Synchronous private link (gRPC/HTTPS/mTLS)&lt;br/&gt;Dashed: Async event bus / eventual consistency&lt;br/&gt;Thick: Cross-cloud or WAN private fabric&lt;br/&gt;&lt;/span&gt;&lt;br/&gt;&lt;b&gt;Layers&lt;/b&gt; (drawio Edit -&amp;gt; Layers): Groupings * Services * Directors * Connectors * Overlays.&lt;/span&gt;" vertex="1">
          <mxGeometry height="210" width="900" x="40" y="1744" as="geometry" />
