{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ADAM-AGT Evidence Record Schema",
  "description": "Schema for evidence records generated by AGT enforcement actions that feed into ADAM's Flight Recorder. Immutable hash-chained WORM (Write-Once-Read-Many) records linking agent actions, policy enforcement, and BOSS decisions.",
  "type": "object",
  "required": [
    "recordId",
    "timestamp",
    "recordType",
    "agentDid",
    "entryHash",
    "sealed"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema version"
    },
    "recordId": {
      "type": "string",
      "description": "Unique immutable identifier for this Flight Recorder entry",
      "pattern": "^fr-[a-f0-9]{16}$"
    },
    "sequenceNumber": {
      "type": "integer",
      "description": "Monotonically increasing sequence number in Flight Recorder",
      "minimum": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when event occurred"
    },
    "recordedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when event was recorded in Flight Recorder"
    },
    "recordType": {
      "type": "string",
      "description": "Type of evidence being recorded",
      "enum": [
        "policy-enforcement",
        "boss-score-update",
        "agent-action",
        "exception-escalation",
        "trust-score-change",
        "autonomy-budget-usage",
        "compliance-check",
        "kill-switch-activation",
        "saga-completion",
        "audit-event",
        "security-incident"
      ]
    },
    "severity": {
      "type": "string",
      "description": "Severity level of event",
      "enum": [
        "informational",
        "warning",
        "critical",
        "emergency"
      ]
    },
    "actor": {
      "type": "object",
      "description": "Actor responsible for this event",
      "properties": {
        "actorDid": {
          "type": "string",
          "description": "DID of acting agent"
        },
        "actorType": {
          "type": "string",
          "description": "Type of actor (agent, system, human)"
        },
        "actorLayer": {
          "type": "string",
          "description": "ADAM canonical 6 agent classes + meta-governance class. Legacy *-layer aliases retained for backwards compatibility with v1.0 contracts.",
          "enum": [
            "meta-governance-class",
            "governor-agent-class",
            "orchestration-class",
            "human-interface-class",
            "digital-twin-class",
            "work-group-class",
            "ai-centric-division-class",
            "intent-layer",
            "governor-agent-layer",
            "orchestration-layer",
            "workgroup-layer",
            "digital-twin-layer"
          ]
        }
      }
    },
    "agentDid": {
      "type": "string",
      "description": "Primary agent subject of this record",
      "pattern": "^did:adam:[a-zA-Z0-9-]+$"
    },
    "relatedAgents": {
      "type": "array",
      "description": "Other agents involved in this event",
      "items": {
        "type": "object",
        "properties": {
          "agentDid": {"type": "string"},
          "relationship": {
            "type": "string",
            "enum": ["caller", "approver", "escalator", "executor", "validator"]
          }
        }
      }
    },
    "policyEnforcement": {
      "type": "object",
      "description": "Details if this is a policy enforcement event",
      "properties": {
        "policyContractId": {
          "type": "string"
        },
        "policyName": {
          "type": "string"
        },
        "ruleEvaluated": {
          "type": "string"
        },
        "evaluationResult": {
          "type": "string",
          "enum": ["allow", "deny", "escalate", "block"]
        },
        "enforcementAction": {
          "type": "string",
          "description": "Action taken as result of policy enforcement"
        },
        "decisionLatencyMs": {
          "type": "number",
          "description": "Time taken to evaluate policy decision"
        },
        "policySource": {
          "type": "string",
          "description": "Which ADAM component sourced this policy"
        }
      }
    },
    "bossScoreContext": {
      "type": "object",
      "description": "BOSS score snapshot at time of event",
      "properties": {
        "overallScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "escalationTier": {
          "type": "string",
          "enum": ["SOAP", "MODERATE", "ELEVATED", "HIGH", "OHSHAT"]
        },
        "dimensionScores": {
          "type": "object",
          "properties": {
            "security": {"type": "number"},
            "sovereignty": {"type": "number"},
            "financial": {"type": "number"},
            "regulatory": {"type": "number"},
            "reputational": {"type": "number"},
            "rights": {"type": "number"},
            "doctrinal": {"type": "number"}
          }
        },
        "scoreDelta": {
          "type": "number",
          "description": "Change in BOSS score since last record"
        }
      }
    },
    "agentAction": {
      "type": "object",
      "description": "Details of agent action being recorded",
      "properties": {
        "actionType": {
          "type": "string",
          "description": "Type of action performed"
        },
        "actionName": {
          "type": "string"
        },
        "parameters": {
          "type": "object",
          "description": "Action parameters (sanitized of sensitive data)"
        },
        "intentObjectRef": {
          "type": "string",
          "description": "Reference to originating ADAM intent object"
        },
        "executionStatus": {
          "type": "string",
          "enum": ["initiated", "in-progress", "completed", "failed", "rolled-back"]
        },
        "executionDurationMs": {
          "type": "number",
          "description": "Time taken for action execution"
        }
      }
    },
    "exceptionEscalation": {
      "type": "object",
      "description": "Details if event involved exception economy escalation",
      "properties": {
        "escalationTrigger": {
          "type": "string",
          "description": "What triggered escalation"
        },
        "escalationLevel": {
          "type": "integer",
          "description": "Level of escalation (1-N)"
        },
        "escalatedTo": {
          "type": "string",
          "description": "DID or role escalated to"
        },
        "autonomyBudgetImpact": {
          "type": "number",
          "description": "Autonomy budget consumed by escalation"
        },
        "resolvedBy": {
          "type": "string",
          "description": "DID of resolver"
        },
        "resolutionTime": {
          "type": "integer",
          "description": "Time to resolution (seconds)"
        }
      }
    },
    "trustScore": {
      "type": "object",
      "description": "Trust score snapshot at time of event",
      "properties": {
        "priorScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1000
        },
        "currentScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1000
        },
        "scoreDelta": {
          "type": "number"
        },
        "authorityLevel": {
          "type": "string",
          "enum": ["QUARANTINED", "RESTRICTED", "STANDARD", "ELEVATED", "TRUSTED"]
        },
        "factorChanges": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "factor": {"type": "string"},
              "priorValue": {"type": "number"},
              "currentValue": {"type": "number"}
            }
          }
        }
      }
    },
    "autonomyBudget": {
      "type": "object",
      "description": "Autonomy budget impact of this event",
      "properties": {
        "budgetAccountId": {
          "type": "string",
          "description": "Which budget account was charged"
        },
        "costIncurred": {
          "type": "number",
          "description": "Autonomy budget cost of this action"
        },
        "remainingBudget": {
          "type": "number",
          "description": "Budget remaining after this action"
        },
        "budgetExhaustion": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Percentage of budget exhausted (0.0-1.0)"
        },
        "budgetPeriod": {
          "type": "string",
          "description": "Time window for this budget allocation"
        }
      }
    },
    "compliance": {
      "type": "object",
      "description": "Compliance implications of this event",
      "properties": {
        "complianceFramework": {
          "type": "string",
          "enum": [
            "eu-ai-act",
            "dora",
            "nis2",
            "singapore-imda",
            "hipaa",
            "soc2"
          ]
        },
        "complianceStatus": {
          "type": "string",
          "enum": ["compliant", "non-compliant", "requires-review"]
        },
        "requiredAction": {
          "type": "string",
          "description": "Action required for compliance"
        },
        "auditableEvent": {
          "type": "boolean",
          "description": "Whether this event is auditble for compliance"
        }
      }
    },
    "killSwitch": {
      "type": "object",
      "description": "Details if kill switch was activated",
      "properties": {
        "activated": {
          "type": "boolean"
        },
        "trigger": {
          "type": "string",
          "description": "What triggered kill switch"
        },
        "affectedAgents": {
          "type": "array",
          "items": {"type": "string"}
        },
        "gracefulShutdownInitiated": {
          "type": "boolean"
        },
        "forensicsCollected": {
          "type": "boolean"
        }
      }
    },
    "sagaExecution": {
      "type": "object",
      "description": "Details if this event relates to saga execution",
      "properties": {
        "sagaId": {
          "type": "string"
        },
        "sagaStatus": {
          "type": "string",
          "enum": ["started", "step-completed", "step-failed", "compensating", "completed", "failed"]
        },
        "currentStep": {
          "type": "integer"
        },
        "totalSteps": {
          "type": "integer"
        },
        "compensationTriggered": {
          "type": "boolean"
        }
      }
    },
    "hashChain": {
      "type": "object",
      "description": "Hash-chain linkage for immutability verification",
      "required": ["entryHash", "previousHash"],
      "properties": {
        "entryHash": {
          "type": "string",
          "description": "SHA-256 hash of this entry (created before sealing)",
          "pattern": "^[a-f0-9]{64}$"
        },
        "previousHash": {
          "type": "string",
          "description": "SHA-256 hash of previous entry (creates chain)",
          "pattern": "^[a-f0-9]{64}$"
        },
        "hashAlgorithm": {
          "type": "string",
          "default": "SHA-256"
        },
        "chainValid": {
          "type": "boolean",
          "description": "Validation that hash chain is unbroken"
        }
      }
    },
    "wormCompliance": {
      "type": "object",
      "description": "Write-Once-Read-Many (WORM) compliance status",
      "required": ["sealed"],
      "properties": {
        "sealed": {
          "type": "boolean",
          "description": "Whether entry is sealed (immutable)"
        },
        "sealedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When entry was sealed"
        },
        "sealedBy": {
          "type": "string",
          "description": "DID of sealing authority"
        },
        "retentionUntil": {
          "type": "string",
          "format": "date-time",
          "description": "Date until which this record must be retained"
        },
        "sealingSignature": {
          "type": "string",
          "description": "Ed25519 signature proving immutability"
        }
      }
    },
    "directorConstitution": {
      "type": "object",
      "description": "ADAM 5-Director Constitution context",
      "properties": {
        "directorApprovals": {
          "type": "array",
          "description": "Directors involved in this decision",
          "items": {
            "type": "object",
            "properties": {
              "director": {
                "type": "string",
                "enum": ["CEO", "CFO", "Legal", "Market", "CISO"]
              },
              "approvalStatus": {
                "type": "string",
                "enum": ["pending", "approved", "denied", "abstain"]
              },
              "timestamp": {"type": "string", "format": "date-time"}
            }
          }
        },
        "constitutionalAlignment": {
          "type": "string",
          "description": "Whether action aligns with 5-director constitution"
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata about this record",
      "properties": {
        "source": {
          "type": "string",
          "description": "System component that created this record"
        },
        "environment": {
          "type": "string",
          "enum": ["production", "staging", "development"]
        },
        "region": {
          "type": "string",
          "description": "Geographic region where event occurred"
        },
        "cluster": {
          "type": "string",
          "description": "Kubernetes cluster identifier"
        },
        "namespace": {
          "type": "string",
          "description": "Kubernetes namespace"
        },
        "tags": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Searchable tags for this record"
        }
      }
    },
    "intentObject": {
      "type": "object",
      "description": "Reference to originating ADAM intent object",
      "properties": {
        "intentId": {
          "type": "string",
          "description": "Unique ID of intent object"
        },
        "intentType": {
          "type": "string"
        },
        "intentHash": {
          "type": "string",
          "description": "SHA-256 hash of intent for verification"
        },
        "intentOrigin": {
          "type": "string",
          "description": "Where intent originated (user, system, agent)"
        }
      }
    },
    "relatedRecords": {
      "type": "array",
      "description": "Links to related Flight Recorder entries",
      "items": {
        "type": "object",
        "properties": {
          "recordId": {"type": "string"},
          "relationship": {
            "type": "string",
            "enum": ["parent", "child", "sibling", "compensation", "verification"]
          }
        }
      }
    },
    "signatureAndVerification": {
      "type": "object",
      "description": "Cryptographic proof of authenticity",
      "properties": {
        "signature": {
          "type": "string",
          "description": "Ed25519 signature over record"
        },
        "signedBy": {
          "type": "string",
          "description": "DID of Flight Recorder authority that signed"
        },
        "verificationStatus": {
          "type": "string",
          "enum": ["valid", "invalid", "unverified"],
          "description": "Current signature verification status"
        }
      }
    },
    "auditableContent": {
      "type": "object",
      "description": "Content suitable for external audit and compliance reporting",
      "properties": {
        "regulatoryRelevant": {
          "type": "boolean",
          "description": "Whether this record is relevant to regulatory audit"
        },
        "auditSummary": {
          "type": "string",
          "description": "Concise summary for audit reports"
        },
        "complianceFrameworks": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "recordId": "fr-a1b2c3d4e5f6g7h8",
      "sequenceNumber": 42857,
      "timestamp": "2026-04-11T14:35:22.123Z",
      "recordedAt": "2026-04-11T14:35:22.456Z",
      "recordType": "policy-enforcement",
      "severity": "warning",
      "actor": {
        "actorDid": "did:adam:policy-gateway-001",
        "actorType": "system",
        "actorLayer": "orchestration-layer"
      },
      "agentDid": "did:adam:workgroup-agent-042",
      "policyEnforcement": {
        "policyContractId": "policy-contract-budget-control-001",
        "policyName": "Financial Budget Control",
        "evaluationResult": "escalate",
        "enforcementAction": "escalate-to-cfo"
      },
      "bossScoreContext": {
        "overallScore": 65,
        "escalationTier": "HIGH",
        "dimensionScores": {
          "security": 35,
          "financial": 70,
          "regulatory": 60
        }
      },
      "autonomyBudget": {
        "budgetAccountId": "budget-workgroup-042-2026-04",
        "costIncurred": 250,
        "remainingBudget": 750,
        "budgetExhaustion": 0.25
      },
      "hashChain": {
        "entryHash": "8f4e9a2b3c1d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d",
        "previousHash": "7d3e8a9b2c0e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f"
      },
      "wormCompliance": {
        "sealed": true,
        "sealedAt": "2026-04-11T14:35:22.789Z",
        "sealedBy": "did:adam:flight-recorder-001",
        "retentionUntil": "2035-04-11T00:00:00Z"
      }
    }
  ]
}
